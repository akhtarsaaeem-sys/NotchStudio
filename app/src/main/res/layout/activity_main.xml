<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_root"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="8dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp">
                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_glow_orange" />
                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:contentDescription="@string/app_name" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Design your notch, your way"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 1: Content input + actions -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Content"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/inputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:background="@null"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:hint="Type text or emoji..."
                    android:textCursorDrawable="@null"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/divider_line"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="18dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="22dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyText"
                        style="@style/Widget.App.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Launch"
                        app:icon="@drawable/ic_play"
                        app:iconSize="18dp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopService"
                        style="@style/Widget.App.Button.Neutral"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Stop"
                        app:icon="@drawable/ic_stop"
                        app:iconSize="18dp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/divider_line"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFreeCrop"
                    style="@style/Text.SwitchLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Unlock Image Proportions"
                    app:thumbTint="@color/orange_primary"
                    app:trackTint="@color/surface_pressed"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickImage"
                    style="@style/Widget.App.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Crop &amp; Apply Image"
                    app:icon="@drawable/ic_image"
                    app:iconSize="18dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2: Appearance -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_palette"
                        android:tint="@color/orange_primary" />

                    <TextView
                        style="@style/Text.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Appearance" />
                </LinearLayout>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notch Background"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorBgBlack" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#000000" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorBgWhite" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorBgPurple" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#6200EA" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorBgBlue" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#0D47A1" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorBgRed" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#B71C1C" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                </LinearLayout>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text Color"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorTextWhite" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#FFFFFF" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorTextBlack" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#000000" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorTextYellow" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#FFEA00" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorTextCyan" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#00E5FF" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/colorTextPink" android:layout_width="42dp" android:layout_height="42dp" android:layout_marginHorizontal="7dp" app:cardBackgroundColor="#FF007F" app:cardCornerRadius="21dp" app:strokeColor="@color/stroke_strong" app:strokeWidth="1dp" app:cardElevation="0dp" app:rippleColor="@color/orange_ripple"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3: Bubble Size -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_resize"
                        android:tint="@color/orange_primary" />

                    <TextView
                        style="@style/Text.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Bubble Size" />
                </LinearLayout>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Width" />
                <SeekBar
                    android:id="@+id/seekWidth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:progressDrawable="@drawable/seekbar_progress"
                    android:thumb="@drawable/seekbar_thumb"
                    android:min="50"
                    android:max="1000"/>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Height" />
                <SeekBar
                    android:id="@+id/seekHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:progressDrawable="@drawable/seekbar_progress"
                    android:thumb="@drawable/seekbar_thumb"
                    android:min="30"
                    android:max="500"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 4: Fine-Tune Position -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_centerVertical="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_target"
                            android:tint="@color/orange_primary" />

                        <TextView
                            style="@style/Text.SectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="Fine-Tune Position" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetPosition"
                        style="@style/Widget.App.Button.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Reset"
                        app:icon="@drawable/ic_refresh"
                        app:iconSize="14dp"
                        android:paddingHorizontal="10dp"/>
                </RelativeLayout>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Left / Right (X)" />
                <SeekBar
                    android:id="@+id/seekX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:progressDrawable="@drawable/seekbar_progress"
                    android:thumb="@drawable/seekbar_thumb"
                    android:min="-500"
                    android:max="1500"/>

                <TextView
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Up / Down (Y)" />
                <SeekBar
                    android:id="@+id/seekY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:progressDrawable="@drawable/seekbar_progress"
                    android:thumb="@drawable/seekbar_thumb"
                    android:min="-500"
                    android:max="2000"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
