<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Cards -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/stroke_subtle</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/orange_primary</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">14dp</item>
        <item name="iconTint">@color/black</item>
        <item name="iconGravity">textStart</item>
        <item name="rippleColor">#33000000</item>
    </style>

    <style name="Widget.App.Button.Neutral" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/surface_alt</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/stroke_strong</item>
        <item name="strokeWidth">1dp</item>
        <item name="iconTint">@color/text_secondary</item>
        <item name="iconGravity">textStart</item>
        <item name="rippleColor">@color/orange_ripple</item>
    </style>

    <style name="Widget.App.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/orange_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/orange_primary</item>
        <item name="strokeWidth">1.4dp</item>
        <item name="iconTint">@color/orange_primary</item>
        <item name="iconGravity">textStart</item>
        <item name="rippleColor">@color/orange_ripple</item>
    </style>

    <style name="Widget.App.Button.Chip" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/surface_alt</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">11sp</item>
        <item name="cornerRadius">10dp</item>
        <item name="iconTint">@color/text_secondary</item>
        <item name="iconGravity">textStart</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/orange_ripple</item>
    </style>

    <!-- Typography -->
    <style name="Text.SectionTitle" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Text.Label" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Text.SwitchLabel" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
